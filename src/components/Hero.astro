---
---

<section
  id="hero"
  class="hero-section"
  style="
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 100px 56px 80px;
  "
>
  <!-- ═══════════════════════════════════════════════════
       LAYER 1 — atmosphere (grid + particles + meshes)
       ═══════════════════════════════════════════════════ -->
  <div style="position: absolute; inset: 0; pointer-events: none; z-index: 0;">
    <div class="grid-bg" style="position: absolute; inset: 0; opacity: 0.4;"></div>
    <div id="hero-particles" style="position: absolute; inset: 0;"></div>
    <!-- Right-side spotlight echoing where image sits -->
    <div class="hero-right-spotlight"></div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       LAYER 2 — content grid (text left, image right)
       ═══════════════════════════════════════════════════ -->
  <div class="hero-grid" style="position: relative; z-index: 3; max-width: 1320px; margin: 0 auto; width: 100%;">

    <!-- ───────── LEFT: TEXT ───────── -->
    <div class="hero-text-col">
      <!-- AVAILABLE FOR WORK badge (clickable to contact) -->
      <a href="/#contact" class="hero-badge" id="hero-badge">
        <span class="pulse-dot" style="box-shadow: 0 0 14px var(--brand-bond);"></span>
        <span style="text-transform: uppercase; letter-spacing: 1.5px;">Available for work</span>
        <span style="color: var(--text-3); font-weight: 400;">·</span>
        <span class="hero-badge-cta">Hiring? Let's talk <span class="hero-badge-arrow">→</span></span>
      </a>

      <h1
        id="hero-title"
        class="hero-title"
      >
        <span class="hero-line-1">Built with</span>
        <span class="hero-line-2"><span class="gradient-text-1">brain</span> <span class="hero-amp">&amp;</span> <span class="gradient-text-2">bricks.</span></span>
      </h1>

      <p id="hero-sub" class="hero-sub">
        We're a <strong style="color: var(--text-1);">duo studio</strong> — Principal iOS engineering meets structural QC inspection.
        Currently shipping <strong style="color: var(--brand-1);">FootSteps</strong> on the App Store, plus enterprise iOS work and 12+ years of precast quality control across the UAE.
      </p>

      <div id="hero-btns" class="hero-btns">
        <a href="/#projects" class="btn-primary">
          <span>View Our Work</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
        <a href="/arslan" class="btn-ghost">Meet with Arslan</a>
        <a href="/bilal" class="btn-ghost">Meet with M. Bilal</a>
      </div>

      <!-- Glassmorphism stats card -->
      <div id="hero-stats" class="hero-stats-card">
        <div class="hero-stat">
          <div class="hero-stat-num">6<span class="hero-stat-plus">+</span></div>
          <div class="hero-stat-label">Years iOS</div>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <div class="hero-stat-num">12<span class="hero-stat-plus">+</span></div>
          <div class="hero-stat-label">Apps Shipped</div>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <div class="hero-stat-num">12<span class="hero-stat-plus">+</span></div>
          <div class="hero-stat-label">Years Precast QC</div>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <div class="hero-stat-num">🏆</div>
          <div class="hero-stat-label">EoM 2023</div>
        </div>
      </div>
    </div>

    <!-- ───────── RIGHT: PORTRAIT WITH 3D EFFECTS ───────── -->
    <div class="hero-image-col">
      <!-- Backplate: rotating logo + radial gradient -->
      <div class="hero-image-backplate" aria-hidden="true">
        <!-- Radial green gradient backdrop -->
        <div class="hero-image-glow"></div>
        <!-- Rotating subtle cube logo -->
        <div class="hero-image-cube spin-slow-3d">
          <svg viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg">
            <polygon points="120,10 220,60 120,110 20,60" fill="var(--brand-1)" opacity="0.7"/>
            <polygon points="20,60 120,110 120,220 20,170" fill="var(--brand-1-dark)" opacity="0.85"/>
            <polygon points="120,110 220,60 220,170 120,220" fill="var(--brand-2)" opacity="0.7"/>
            <circle cx="120" cy="10" r="8" fill="var(--brand-bond)"/>
            <circle cx="120" cy="10" r="16" fill="var(--brand-bond)" opacity="0.3"/>
          </svg>
        </div>
        <!-- Rim light arc behind subject -->
        <div class="hero-image-rim"></div>
      </div>

      <!-- The portrait itself with floating animation -->
      <div class="hero-image-wrap" id="hero-image-wrap">
        <img
          src="/arslan-cutout.png"
          alt="Arslan Ahmad — Principal iOS Engineer"
          class="hero-portrait"
          loading="eager"
          fetchpriority="high"
        />
        <!-- Bottom fade mask blends image into bg -->
        <div class="hero-image-bottom-fade"></div>
      </div>

      <!-- Floating tech tags -->
      <div class="hero-float-tag hide-mobile float-tag-1">
        <span class="pulse-dot"></span>
        <span>FootSteps · Live</span>
      </div>
      <div class="hero-float-tag hide-mobile float-tag-2">
        <span>✦ SwiftUI</span>
      </div>
      <div class="hero-float-tag hide-mobile float-tag-3">
        <span>◈ Structural QC</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll-hint hide-mobile">
    <span>Scroll</span>
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M7 1v12M1 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </div>
</section>

<style>
  /* ═══ GRID LAYOUT ═══ */
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* ═══ RIGHT-SIDE SPOTLIGHT ═══ */
  .hero-right-spotlight {
    position: absolute;
    right: -10%;
    top: 0;
    bottom: 0;
    width: 65%;
    background:
      radial-gradient(circle at 50% 50%,
        color-mix(in srgb, var(--brand-1) 18%, transparent) 0%,
        transparent 55%),
      radial-gradient(circle at 40% 30%,
        color-mix(in srgb, var(--brand-bond) 8%, transparent) 0%,
        transparent 40%);
    filter: blur(20px);
  }

  /* ═══ BADGE (clickable link) ═══ */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: color-mix(in srgb, var(--brand-bond) 8%, var(--bg-1));
    border: 1px solid color-mix(in srgb, var(--brand-bond) 30%, transparent);
    border-radius: 100px;
    padding: 8px 18px;
    font-size: 12px;
    color: var(--text-1);
    font-weight: 600;
    margin-bottom: 32px;
    box-shadow: 0 6px 24px color-mix(in srgb, var(--brand-bond) 14%, transparent);
    backdrop-filter: blur(14px);
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .hero-badge:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--brand-bond) 60%, transparent);
    box-shadow: 0 10px 32px color-mix(in srgb, var(--brand-bond) 25%, transparent);
  }
  .hero-badge-cta {
    color: var(--brand-bond);
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .hero-badge-arrow {
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }
  .hero-badge:hover .hero-badge-arrow {
    transform: translateX(4px);
  }

  /* ═══ HEADLINE ═══ */
  .hero-title {
    font-size: clamp(48px, 6.5vw, 96px);
    font-weight: 900;
    letter-spacing: -2.5px;
    line-height: 0.98;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    margin-bottom: 26px;
    color: var(--text-1);
  }
  .hero-line-1 { display: block; }
  .hero-line-2 { display: block; }
  .hero-amp {
    color: var(--text-3);
    font-weight: 300;
    margin: 0 6px;
  }

  /* ═══ SUBTITLE ═══ */
  .hero-sub {
    font-size: 17px;
    color: var(--text-2);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 540px;
  }

  /* ═══ CTAS ═══ */
  .hero-btns {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  /* ═══ GLASSMORPHISM STATS CARD ═══ */
  .hero-stats-card {
    display: flex;
    align-items: center;
    gap: 28px;
    background: var(--bg-glass);
    border: 1px solid var(--border-1);
    border-radius: 20px;
    padding: 22px 28px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    max-width: 600px;
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-stat-num {
    font-size: 26px;
    font-weight: 900;
    color: var(--text-1);
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1;
  }
  .hero-stat-plus {
    color: var(--brand-1);
  }
  .hero-stat-label {
    font-size: 10.5px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 500;
  }
  .hero-stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border-1);
  }

  /* ═══════════════════════════════════════════════════
     RIGHT COLUMN: PORTRAIT WITH 3D EFFECTS
     ═══════════════════════════════════════════════════ */
  .hero-image-col {
    position: relative;
    height: 100%;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Backplate — green radial glow + rotating cube */
  .hero-image-backplate {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }
  .hero-image-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    max-width: 90vw;
    border-radius: 50%;
    background: radial-gradient(circle at center,
      color-mix(in srgb, var(--brand-1) 22%, transparent) 0%,
      color-mix(in srgb, var(--brand-1) 8%, transparent) 30%,
      transparent 60%);
    filter: blur(40px);
  }
  .hero-image-cube {
    position: absolute;
    width: 480px;
    height: 480px;
    max-width: 70vw;
    opacity: 0.12;
    filter: blur(0.6px) drop-shadow(0 0 60px color-mix(in srgb, var(--brand-1) 50%, transparent));
    transform-style: preserve-3d;
    perspective: 1200px;
  }
  .hero-image-cube svg {
    width: 100%;
    height: 100%;
  }
  .hero-image-rim {
    position: absolute;
    width: 460px;
    height: 460px;
    max-width: 78vw;
    border-radius: 50%;
    background: conic-gradient(
      from 180deg at 50% 50%,
      transparent 0deg,
      color-mix(in srgb, var(--brand-bond) 35%, transparent) 80deg,
      color-mix(in srgb, var(--brand-1) 30%, transparent) 140deg,
      transparent 220deg,
      transparent 360deg
    );
    filter: blur(50px);
    opacity: 0.5;
  }

  /* Portrait wrapper — floats continuously, scales on hover */
  .hero-image-wrap {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 600px;
    aspect-ratio: 2/3;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    animation: heroFloat 6s ease-in-out infinite;
  }
  .hero-image-wrap:hover {
    transform: translateY(-12px) scale(1.02);
  }
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }

  .hero-portrait {
    width: 100%;
    height: auto;
    max-height: 110%;            /* slight vertical overflow for depth */
    object-fit: contain;
    object-position: bottom center;
    mix-blend-mode: lighten;     /* blends dark vignette bg with theme bg */
    filter:
      drop-shadow(0 35px 60px rgba(0, 0, 0, 0.7))
      drop-shadow(0 -6px 28px color-mix(in srgb, var(--brand-1) 30%, transparent));
    /* Two stacked masks intersect:
       1. Radial vignette — fades all corners
       2. Linear bottom fade — kills the bottom rectangle decisively
       This eliminates the rectangular box feel entirely. */
    -webkit-mask-image:
      radial-gradient(
        ellipse 60% 70% at 50% 45%,
        #000 0%,
        #000 30%,
        rgba(0,0,0,0.85) 55%,
        rgba(0,0,0,0.35) 78%,
        transparent 100%
      ),
      linear-gradient(180deg,
        #000 0%,
        #000 65%,
        rgba(0,0,0,0.5) 80%,
        transparent 95%
      );
    -webkit-mask-composite: source-in;
            mask-composite: intersect;
    mask-image:
      radial-gradient(
        ellipse 60% 70% at 50% 45%,
        #000 0%,
        #000 30%,
        rgba(0,0,0,0.85) 55%,
        rgba(0,0,0,0.35) 78%,
        transparent 100%
      ),
      linear-gradient(180deg,
        #000 0%,
        #000 65%,
        rgba(0,0,0,0.5) 80%,
        transparent 95%
      );
  }

  /* Bottom fade mask — additional theme-bg gradient to fully kill the bottom edge */
  .hero-image-bottom-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 38%;
    background: linear-gradient(0deg, var(--bg-0) 0%, var(--bg-0) 20%, transparent 100%);
    pointer-events: none;
    z-index: 3;
  }

  /* ═══ FLOATING TECH TAGS ═══ */
  .hero-float-tag {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: color-mix(in srgb, var(--bg-1) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-1) 30%, transparent);
    border-radius: 12px;
    padding: 8px 14px;
    font-size: 12px;
    color: var(--brand-1);
    font-weight: 600;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    z-index: 5;
    white-space: nowrap;
  }
  .float-tag-1 {
    top: 12%;
    right: -10%;
    animation: floatTag 4s ease-in-out infinite;
  }
  .float-tag-2 {
    top: 42%;
    right: -2%;
    color: var(--brand-bond);
    border-color: color-mix(in srgb, var(--brand-bond) 30%, transparent);
    animation: floatTag 5s ease-in-out infinite 0.7s;
  }
  .float-tag-3 {
    bottom: 28%;
    left: -8%;
    color: var(--brand-2);
    border-color: color-mix(in srgb, var(--brand-2) 30%, transparent);
    animation: floatTag 4.5s ease-in-out infinite 1.4s;
  }

  /* ═══ SCROLL HINT ═══ */
  .hero-scroll-hint {
    position: absolute;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--text-2);
    opacity: 0.5;
    animation: floatTag 2s ease-in-out infinite;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    z-index: 6;
  }

  /* ═══ SLOW 3D ROTATION ═══ */
  .spin-slow-3d {
    animation: spinSlow3D 50s linear infinite;
  }
  @keyframes spinSlow3D {
    0%   { transform: rotateY(0deg)   rotateX(0deg); }
    50%  { transform: rotateY(180deg) rotateX(8deg); }
    100% { transform: rotateY(360deg) rotateX(0deg); }
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE — tablet / mobile stack vertical
     ═══════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .hero-section {
      padding: 100px 24px 60px !important;
      min-height: auto !important;
    }
    .hero-grid {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
      text-align: center;
    }
    .hero-image-col {
      order: -1;                /* image goes ABOVE text on mobile/tablet */
      min-height: 420px;
    }
    .hero-image-wrap {
      max-width: 380px;
    }
    .hero-image-glow {
      width: 460px;
      height: 460px;
    }
    .hero-image-cube { width: 320px; height: 320px; }
    .hero-image-rim { width: 320px; height: 320px; }

    .hero-text-col {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-badge { font-size: 10.5px; }
    .hero-title { font-size: clamp(38px, 8vw, 64px) !important; }
    .hero-sub { text-align: center; }
    .hero-btns { justify-content: center; }
    .hero-stats-card {
      flex-wrap: wrap;
      justify-content: center;
      gap: 18px;
    }
    .hero-stat-divider { display: none; }
    .hero-right-spotlight { display: none; }
  }

  @media (max-width: 640px) {
    .hero-stats-card { padding: 18px 20px; gap: 16px; }
    .hero-stat-num { font-size: 22px; }
    .hero-stat-label { font-size: 9.5px; }
  }
</style>

<script>
  import gsap from 'gsap';

  // Particles
  const container = document.getElementById('hero-particles');
  if (container) {
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 2.5 + 0.5;
      p.style.cssText = `
        width: ${size}px; height: ${size}px;
        left: ${Math.random() * 100}%; top: ${Math.random() * 100}%;
        opacity: ${Math.random() * 0.35 + 0.05};
        animation: floatTag ${Math.random() * 12 + 6}s ease-in-out infinite;
        animation-delay: -${Math.random() * 8}s;
      `;
      container.appendChild(p);
    }
  }

  // Entrance timeline
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('#hero-badge', { opacity: 0, y: 20, duration: 0.6 })
    .from('#hero-title', { opacity: 0, y: 40, duration: 0.9 }, '-=0.3')
    .from('#hero-sub', { opacity: 0, y: 25, duration: 0.6 }, '-=0.4')
    .from('#hero-btns', { opacity: 0, y: 20, duration: 0.5 }, '-=0.3')
    .from('#hero-stats', { opacity: 0, y: 20, duration: 0.6 }, '-=0.3')
    .from('.hero-image-wrap', { opacity: 0, scale: 0.92, duration: 1.0, ease: 'power3.out' }, '-=1.4')
    .from('.hero-float-tag', { opacity: 0, y: 20, duration: 0.5, stagger: 0.12 }, '-=0.4');

  // Mouse-follow tilt on portrait
  const imageWrap = document.getElementById('hero-image-wrap');
  if (imageWrap) {
    const heroEl = document.querySelector<HTMLElement>('.hero-section');
    heroEl?.addEventListener('mousemove', (e) => {
      const evt = e as MouseEvent;
      const rect = heroEl.getBoundingClientRect();
      const x = (evt.clientX - rect.left) / rect.width - 0.5;
      const y = (evt.clientY - rect.top) / rect.height - 0.5;
      imageWrap.style.transform = `translateY(${y * 18}px) translateX(${x * 12}px) rotate(${x * 1.5}deg)`;
    });
    heroEl?.addEventListener('mouseleave', () => {
      imageWrap.style.transform = '';
    });
  }
</script>
