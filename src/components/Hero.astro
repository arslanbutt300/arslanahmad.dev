---
---

<section
  id="hero"
  style="
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 0 48px;
    padding-top: 64px;
  "
>
  <!-- Background layers -->
  <div style="position: absolute; inset: 0; pointer-events: none;">
    <!-- Radial glow -->
    <div style="
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 70% at 65% 50%, rgba(127,119,221,0.1) 0%, transparent 65%),
        radial-gradient(ellipse 40% 50% at 20% 80%, rgba(90,240,192,0.04) 0%, transparent 60%);
    "></div>
    <!-- Grid lines -->
    <div class="grid-bg" style="position: absolute; inset: 0; opacity: 0.8;"></div>
    <!-- Particles container -->
    <div id="hero-particles" style="position: absolute; inset: 0;"></div>
  </div>

  <!-- Left: Text content -->
  <div
    style="
      position: relative;
      z-index: 2;
      flex: 1;
      max-width: 560px;
    "
  >
    <!-- Available badge -->
    <div class="badge" style="margin-bottom: 24px;" id="hero-badge">
      <div class="pulse-dot"></div>
      Available for freelance &amp; consulting
    </div>

    <!-- H1 -->
    <h1
      id="hero-title"
      style="
        font-size: clamp(44px, 6vw, 72px);
        font-weight: 900;
        letter-spacing: -2px;
        line-height: 1.0;
        margin-bottom: 20px;
      "
    >
      <span style="color: var(--text-3);">Lead</span> iOS<br />
      <span class="gradient-text">Developer.</span>
    </h1>

    <!-- Subtitle -->
    <p
      id="hero-sub"
      style="
        font-size: 16px;
        color: var(--text-2);
        line-height: 1.75;
        margin-bottom: 32px;
        max-width: 440px;
      "
    >
      I build <strong style="color: var(--text-1);">high-performance iOS apps</strong> with SwiftUI —
      from GPS trail engines to AI-powered workflows. Currently shipping
      <strong style="color: var(--accent);">FootSteps</strong> on the App Store.
    </p>

    <!-- CTA Buttons -->
    <div id="hero-btns" style="display: flex; gap: 12px; align-items: center; margin-bottom: 52px;">
      <a
        href="/#projects"
        style="
          background: var(--accent);
          color: #fff;
          padding: 14px 28px;
          border-radius: 10px;
          font-size: 14px;
          font-weight: 700;
          transition: opacity 0.2s, transform 0.2s;
          letter-spacing: 0.01em;
        "
        class="hero-btn-primary"
      >
        View Projects
      </a>
      <a
        href="/blog"
        style="
          background: transparent;
          color: var(--text-2);
          padding: 14px 28px;
          border-radius: 10px;
          font-size: 14px;
          font-weight: 600;
          border: 1px solid var(--border);
          transition: all 0.2s;
          letter-spacing: 0.01em;
        "
        class="hero-btn-secondary"
      >
        Read Blog →
      </a>
    </div>

    <!-- Stats -->
    <div id="hero-stats" style="display: flex; gap: 36px;">
      <div>
        <div style="font-size: 28px; font-weight: 900; color: var(--text-1);">
          5<span style="color: var(--accent);">+</span>
        </div>
        <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">
          Years iOS
        </div>
      </div>
      <div style="width: 1px; background: var(--border);"></div>
      <div>
        <div style="font-size: 28px; font-weight: 900; color: var(--text-1);">
          10<span style="color: var(--accent);">+</span>
        </div>
        <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">
          Apps Shipped
        </div>
      </div>
      <div style="width: 1px; background: var(--border);"></div>
      <div>
        <div style="font-size: 28px; font-weight: 900; color: var(--text-1);">
          1k<span style="color: var(--accent);">+</span>
        </div>
        <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">
          App Users
        </div>
      </div>
    </div>
  </div>

  <!-- Right: Phone mockup (Spline placeholder until scene is designed) -->
  <div
    style="
      position: relative;
      z-index: 2;
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      max-height: 700px;
    "
  >
    <div class="phone-float" style="position: relative;">
      <!-- Glow behind phone -->
      <div style="
        position: absolute;
        inset: -30px;
        border-radius: 60px;
        background: radial-gradient(circle, rgba(127,119,221,0.2) 0%, transparent 70%);
        filter: blur(30px);
      "></div>

      <!-- Phone frame -->
      <div style="
        width: 200px;
        height: 400px;
        background: #0a0a12;
        border-radius: 38px;
        border: 2px solid rgba(127,119,221,0.35);
        position: relative;
        overflow: hidden;
        box-shadow: 0 0 60px rgba(127,119,221,0.2), inset 0 0 0 1px rgba(255,255,255,0.04);
      ">
        <!-- Notch -->
        <div style="
          position: absolute;
          top: 0;
          left: 50%;
          transform: translateX(-50%);
          width: 80px;
          height: 22px;
          background: #0a0a12;
          border-radius: 0 0 14px 14px;
          z-index: 3;
        "></div>

        <!-- Screen content -->
        <div style="
          position: absolute;
          inset: 0;
          padding: 30px 14px 14px;
          display: flex;
          flex-direction: column;
          gap: 8px;
        ">
          <div style="font-size: 10px; color: var(--text-3); font-weight: 600;">FootSteps</div>

          <!-- Map area -->
          <div style="
            height: 160px;
            background: linear-gradient(160deg, #0f1a2e 0%, #132233 100%);
            border-radius: 16px;
            position: relative;
            overflow: hidden;
          ">
            <svg width="100%" height="100%" viewBox="0 0 172 160" xmlns="http://www.w3.org/2000/svg">
              <!-- Grid lines -->
              <line x1="0" y1="53" x2="172" y2="53" stroke="#132a45" stroke-width="1"/>
              <line x1="0" y1="106" x2="172" y2="106" stroke="#132a45" stroke-width="1"/>
              <line x1="57" y1="0" x2="57" y2="160" stroke="#132a45" stroke-width="1"/>
              <line x1="114" y1="0" x2="114" y2="160" stroke="#132a45" stroke-width="1"/>
              <!-- Trail path -->
              <defs>
                <linearGradient id="trailGrad" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#7F77DD"/>
                  <stop offset="100%" stop-color="#5af0c0"/>
                </linearGradient>
              </defs>
              <polyline
                points="22,130 38,95 60,78 82,62 106,68 130,48 150,28"
                fill="none"
                stroke="url(#trailGrad)"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <!-- Ghost marker -->
              <circle cx="60" cy="78" r="7" fill="#7F77DD" opacity="0.9"/>
              <circle cx="60" cy="78" r="12" fill="none" stroke="#7F77DD" stroke-width="1.5" opacity="0.3"/>
              <!-- Start / End -->
              <circle cx="22" cy="130" r="5" fill="#34d399"/>
              <circle cx="150" cy="28" r="5" fill="#f59e0b"/>
            </svg>
          </div>

          <!-- Stats row -->
          <div style="display: flex; gap: 6px;">
            {[
              { val: '2.4km', lbl: 'Dist' },
              { val: '32m', lbl: 'Time' },
              { val: '48m', lbl: 'Elev' },
            ].map(s => (
              <div style="
                flex: 1;
                background: rgba(127,119,221,0.1);
                border: 1px solid rgba(127,119,221,0.2);
                border-radius: 8px;
                padding: 6px 4px;
                text-align: center;
              ">
                <div style="font-size: 11px; font-weight: 700; color: var(--accent);">{s.val}</div>
                <div style="font-size: 8px; color: var(--text-3);">{s.lbl}</div>
              </div>
            ))}
          </div>

          <!-- Guide Me button -->
          <div style="
            background: var(--accent);
            border-radius: 10px;
            padding: 9px;
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            color: #fff;
          ">
            👻 Guide Me
          </div>

          <!-- Bottom tabs -->
          <div style="display: flex; gap: 6px; margin-top: 2px;">
            <div style="
              flex: 1; height: 28px;
              background: rgba(127,119,221,0.12);
              border: 1px solid rgba(127,119,221,0.25);
              border-radius: 8px;
              display: flex; align-items: center; justify-content: center;
              font-size: 9px; color: var(--accent); font-weight: 600;
            ">My Trails</div>
            <div style="
              flex: 1; height: 28px;
              background: rgba(255,255,255,0.03);
              border: 1px solid var(--border);
              border-radius: 8px;
              display: flex; align-items: center; justify-content: center;
              font-size: 9px; color: var(--text-3);
            ">Family</div>
          </div>
        </div>
      </div>

      <!-- Orbit tags -->
      <div class="orbit-1" style="
        position: absolute;
        top: 50px;
        right: -80px;
        background: rgba(10,10,18,0.95);
        border: 1px solid rgba(52,211,153,0.3);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 11px;
        color: var(--green);
        white-space: nowrap;
        backdrop-filter: blur(10px);
      ">✦ SwiftUI</div>

      <div class="orbit-2" style="
        position: absolute;
        bottom: 110px;
        right: -90px;
        background: rgba(10,10,18,0.95);
        border: 1px solid rgba(96,165,250,0.3);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 11px;
        color: #60a5fa;
        white-space: nowrap;
        backdrop-filter: blur(10px);
      ">⬡ Supabase</div>

      <div class="orbit-3" style="
        position: absolute;
        top: 140px;
        left: -100px;
        background: rgba(10,10,18,0.95);
        border: 1px solid rgba(245,158,11,0.3);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 11px;
        color: #f59e0b;
        white-space: nowrap;
        backdrop-filter: blur(10px);
      ">◈ CoreLocation</div>

      <div class="orbit-4" style="
        position: absolute;
        top: 260px;
        left: -80px;
        background: rgba(10,10,18,0.95);
        border: 1px solid rgba(127,119,221,0.3);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 11px;
        color: var(--accent);
        white-space: nowrap;
        backdrop-filter: blur(10px);
      ">⚡ Firebase</div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0.4;
    animation: floatTag 2s ease-in-out infinite;
  ">
    <span style="font-size: 11px; color: var(--text-2); letter-spacing: 2px; text-transform: uppercase;">Scroll</span>
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M7 1v12M1 7l6 6 6-6" stroke="var(--text-2)" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </div>
</section>

<style>
  .hero-btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }
  .hero-btn-secondary:hover { border-color: rgba(127,119,221,0.4) !important; color: var(--text-1) !important; }
</style>

<script>
  import gsap from 'gsap';

  // Spawn particles
  const container = document.getElementById('hero-particles');
  if (container) {
    for (let i = 0; i < 35; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 2.5 + 0.5;
      p.style.cssText = `
        width: ${size}px;
        height: ${size}px;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        opacity: ${Math.random() * 0.35 + 0.05};
        animation: floatTag ${Math.random() * 12 + 6}s ease-in-out infinite;
        animation-delay: -${Math.random() * 8}s;
      `;
      container.appendChild(p);
    }
  }

  // Hero entrance animation
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.from('#hero-badge', { opacity: 0, y: 20, duration: 0.6 })
    .from('#hero-title', { opacity: 0, y: 40, duration: 0.7 }, '-=0.3')
    .from('#hero-sub', { opacity: 0, y: 30, duration: 0.6 }, '-=0.4')
    .from('#hero-btns', { opacity: 0, y: 20, duration: 0.5 }, '-=0.3')
    .from('#hero-stats', { opacity: 0, y: 20, duration: 0.5 }, '-=0.3');
</script>
