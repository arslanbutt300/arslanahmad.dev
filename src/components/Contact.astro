---
---

<section
  id="contact"
  style="padding: 120px 48px; border-top: 1px solid var(--border-1);"
>
  <div style="max-width: 640px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <div style="font-size: 11px; color: var(--brand-1); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 12px; font-weight: 600;">
        Contact
      </div>
      <h2 style="font-size: clamp(36px, 5vw, 56px); margin-bottom: 16px; font-family: 'Space Grotesk', sans-serif;">Let's <span class="gradient-text">build</span> something.</h2>
      <p style="color: var(--text-2); font-size: 16px; line-height: 1.75; margin-bottom: 48px;">
        Available for iOS development, QC inspection consulting, and full project builds.
        Reach out at <a href="mailto:hello@brainandbricks.com" style="color: var(--brand-1); font-weight: 600;">hello@brainandbricks.com</a> — we'll reply within 24 hours.
      </p>
    </div>

    <!-- Contact form (Formspree — replace YOUR_FORM_ID) -->
    <form
      class="reveal"
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      style="display: flex; flex-direction: column; gap: 16px; text-align: left;"
    >
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <div>
          <label style="font-size: 12px; color: var(--text-2); display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">Name</label>
          <input
            type="text"
            name="name"
            placeholder="Arslan Ahmad"
            required
            style="
              width: 100%;
              background: var(--bg-1);
              border: 1px solid var(--border-1);
              border-radius: 8px;
              padding: 12px 14px;
              font-size: 14px;
              color: var(--text-1);
              outline: none;
              transition: border-color 0.2s;
              font-family: inherit;
            "
            class="form-input"
          />
        </div>
        <div>
          <label style="font-size: 12px; color: var(--text-2); display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">Email</label>
          <input
            type="email"
            name="email"
            placeholder="hello@example.com"
            required
            style="
              width: 100%;
              background: var(--bg-1);
              border: 1px solid var(--border-1);
              border-radius: 8px;
              padding: 12px 14px;
              font-size: 14px;
              color: var(--text-1);
              outline: none;
              transition: border-color 0.2s;
              font-family: inherit;
            "
            class="form-input"
          />
        </div>
      </div>

      <div>
        <label style="font-size: 12px; color: var(--text-2); display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">Message</label>
        <textarea
          name="message"
          placeholder="Tell me about your project..."
          rows="5"
          required
          style="
            width: 100%;
            background: var(--bg-1);
            border: 1px solid var(--border-1);
            border-radius: 8px;
            padding: 12px 14px;
            font-size: 14px;
            color: var(--text-1);
            outline: none;
            transition: border-color 0.2s;
            font-family: inherit;
            resize: vertical;
          "
          class="form-input"
        ></textarea>
      </div>

      <button
        type="submit"
        class="btn-primary"
        style="border: none; cursor: pointer; font-family: inherit; width: 100%; justify-content: center; padding: 16px 28px; font-size: 14px; font-weight: 700;"
      >
        Send Message →
      </button>
    </form>

    <div class="reveal" style="display: flex; gap: 20px; justify-content: center; margin-top: 48px; flex-wrap: wrap;">
      {[
        { label: 'GitHub', href: 'https://github.com/arslanbutt300' },
        { label: 'LinkedIn', href: '#' },
        { label: 'Twitter/X', href: '#' },
        { label: 'hello@brainandbricks.com', href: 'mailto:hello@brainandbricks.com' },
      ].map(link => (
        <a
          href={link.href}
          style="font-size: 13px; color: var(--text-3); transition: color 0.2s;"
          class="social-link"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .form-input:focus { border-color: var(--brand-1) !important; }
  .form-input::placeholder { color: var(--text-3); }
  .social-link:hover { color: var(--brand-1) !important; }
</style>
