---
const services = [
  // Brain (Arslan) — 4 services
  { icon: '📱', title: 'iOS Development', desc: 'Full-cycle native iOS app development. SwiftUI, UIKit, Objective-C — architecture to App Store submission.', tags: ['SwiftUI', 'UIKit', 'Swift'], side: 'brain' },
  { icon: '🏗️', title: 'App Architecture', desc: 'Clean MVVM, SwiftData modelling, Supabase backend integration, offline-first data strategies.', tags: ['MVVM', 'SwiftData', 'Supabase'], side: 'brain' },
  { icon: '🤖', title: 'AI-Assisted Dev', desc: 'Accelerated development using Claude and ChatGPT as core dev partners. Ship faster, iterate daily.', tags: ['Claude API', 'MCP', 'Tools'], side: 'brain' },
  { icon: '🔒', title: 'Security & Auth', desc: 'Jailbreak detection, SSL pinning, AES-256 encryption, Secure Enclave, Keychain — production-grade.', tags: ['Security', 'Encryption', 'Auth'], side: 'brain' },
  // Mortar (Bilal) — 2 services
  { icon: '🧱', title: 'QC Inspection', desc: 'On-site quality control inspections — materials, structural integrity, compliance verification.', tags: ['QC', 'Audit', 'Inspection'], side: 'mortar' },
  { icon: '📋', title: 'Compliance Reports', desc: 'Detailed inspection reports, code compliance documentation, materials testing analysis.', tags: ['Reports', 'Compliance', 'Standards'], side: 'mortar' },
];
---

<section id="services" style="padding: 120px 48px; border-top: 1px solid var(--border-1);">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="reveal" style="margin-bottom: 56px; max-width: 720px;">
      <div style="font-size: 11px; color: var(--brand-1); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 12px; font-weight: 600;">
        Services
      </div>
      <h2 style="font-size: clamp(36px, 5vw, 56px); font-family: 'Space Grotesk', sans-serif; letter-spacing: -2px;">
        Code and <span class="gradient-text-2">concrete</span>, designed to last.
      </h2>
      <p style="color: var(--text-2); font-size: 16px; margin-top: 14px; line-height: 1.7;">
        Two specialties under one roof. Hire us for app development, QC inspections, or both.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
      {services.map((s, i) => (
        <div class="glass tilt-card reveal-scale" style="border-radius: 16px; padding: 28px 24px; position: relative; overflow: hidden;">
          <div style={`position: absolute; top: -30px; right: -30px; width: 150px; height: 150px; background: radial-gradient(circle, ${s.side === 'brain' ? 'var(--mesh-1)' : 'var(--mesh-2)'} 0%, transparent 70%); filter: blur(25px);`}></div>
          <div style="position: relative;">
            <div style="font-size: 32px; margin-bottom: 14px;">{s.icon}</div>
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 10px; font-family: 'Space Grotesk', sans-serif;">{s.title}</h3>
            <p style="font-size: 13px; color: var(--text-2); line-height: 1.7; margin-bottom: 16px;">{s.desc}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 5px;">
              {s.tags.map(t => (
                <span style={`background: color-mix(in srgb, ${s.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'} 10%, transparent); border: 1px solid color-mix(in srgb, ${s.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'} 25%, transparent); color: ${s.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'}; border-radius: 4px; padding: 3px 9px; font-size: 11px; font-weight: 500;`}>{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="reveal" style="text-align: center; margin-top: 64px;">
      <a href="/#contact" class="btn-primary">
        Let's work together →
      </a>
    </div>
  </div>
</section>
