---
const projects = [
  {
    featured: true,
    tag: '⭐ Featured',
    side: 'brain',
    title: 'FootSteps',
    subtitle: 'GPS Trail Tracking · iOS',
    description: 'Record walking paths, retrace them with real-time ghost navigation, share trails with family. Built with SwiftUI + Google Maps SDK + Supabase. Live on the App Store.',
    badges: ['SwiftUI', 'SwiftData', 'Google Maps', 'Supabase', 'Firebase'],
    links: [
      { label: 'Visit Site →', href: 'https://footsteps.brainandbricks.com' },
      { label: 'App Store ↗', href: 'https://apps.apple.com' },
    ],
  },
  {
    featured: false,
    tag: '🔐 Under NDA',
    side: 'brain',
    title: 'Enterprise iOS',
    subtitle: 'Confidential Client Work',
    description: 'Enterprise iOS work for financial and insurance clients in East & Central Africa. Security-hardened apps, encryption, and SDK integrations.',
    badges: ['Swift', 'Security', 'NDA'],
    links: [{ label: 'Meet Arslan →', href: '/arslan' }],
  },
  {
    featured: false,
    tag: '🚀 Coming Soon',
    side: 'brain',
    title: 'New iOS App',
    subtitle: 'In Planning',
    description: 'A new personal iOS project in early planning. Want to be the first to know? Subscribe via the contact form below.',
    badges: ['SwiftUI', 'AI', 'Coming'],
    links: [{ label: 'Get Notified →', href: '/#contact' }],
  },
  {
    featured: false,
    tag: '🧱 Site Inspections',
    side: 'mortar',
    title: 'Precast QC Portfolio',
    subtitle: 'Construction Quality Assurance',
    description: 'Completed inspections at Exeed Precast Abu Dhabi, RedX Bahrain, Dubai Precast & Rak Precast. 12+ years of precast quality control work.',
    badges: ['Precast', 'QC', 'UAE / Bahrain'],
    links: [{ label: 'Meet Bilal →', href: '/bilal' }],
  },
];
---

<section id="projects" style="padding: 120px 48px; border-top: 1px solid var(--border-1);">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="reveal" style="margin-bottom: 56px; max-width: 720px;">
      <div style="font-size: 11px; color: var(--brand-1); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 12px; font-weight: 600;">
        Featured Work
      </div>
      <h2 style="font-size: clamp(36px, 5vw, 56px); font-family: 'Space Grotesk', sans-serif; letter-spacing: -2px;">
        Things we've <span class="gradient-text">built.</span>
      </h2>
      <p style="color: var(--text-2); font-size: 16px; margin-top: 14px; line-height: 1.7;">
        Apps shipped to the App Store, structures inspected, and projects that ship together.
      </p>
    </div>

    <div class="projects-grid" style="display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: auto auto; gap: 18px;">
      {projects.map((p, i) => (
        <div
          class={`glass tilt-card reveal-scale project-card-${p.featured ? 'featured' : 'small-' + i}`}
          style="
            border-radius: 18px;
            padding: 28px;
            position: relative;
            overflow: hidden;
          "
        >
          <div style={`
            position: absolute; top: -40px; right: -40px;
            width: 200px; height: 200px;
            background: radial-gradient(circle, ${p.side === 'brain' ? 'var(--mesh-1)' : 'var(--mesh-2)'} 0%, transparent 70%);
            filter: blur(30px);
            pointer-events: none;
          `}></div>

          <div style="position: relative;">
            <div style={`
              display: inline-flex;
              background: color-mix(in srgb, ${p.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'} 12%, transparent);
              border: 1px solid color-mix(in srgb, ${p.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'} 25%, transparent);
              border-radius: 6px;
              padding: 4px 10px;
              font-size: 11px;
              color: ${p.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'};
              margin-bottom: 16px;
              font-weight: 600;
            `}>{p.tag}</div>

            <h3 style={`font-size: ${p.featured ? '32px' : '20px'}; font-weight: 800; font-family: 'Space Grotesk', sans-serif; margin-bottom: 4px;`}>
              {p.title}
            </h3>
            <div style={`font-size: 13px; color: ${p.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'}; margin-bottom: 14px; font-weight: 500;`}>
              {p.subtitle}
            </div>

            <p style={`font-size: ${p.featured ? '15px' : '13px'}; color: var(--text-2); line-height: 1.7; margin-bottom: 18px; ${p.featured ? 'max-width: 600px;' : ''}`}>
              {p.description}
            </p>

            <div style="display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 20px;">
              {p.badges.map(b => (
                <span style="background: var(--bg-3); border: 1px solid var(--border-1); border-radius: 4px; padding: 3px 8px; font-size: 10px; color: var(--text-3);">{b}</span>
              ))}
            </div>

            <div style="display: flex; gap: 16px;">
              {p.links.map(link => (
                <a href={link.href} target={link.href.startsWith('/') ? '_self' : '_blank'} style={`font-size: 12px; color: ${p.side === 'brain' ? 'var(--brand-1)' : 'var(--brand-2)'}; font-weight: 600;`}>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .project-card-featured { grid-column: 1 / -1; grid-row: 1; }
  .project-card-small-1 { grid-column: 1; grid-row: 2; }
  .project-card-small-2 { grid-column: 2; grid-row: 2; }
  .project-card-small-3 { grid-column: 3; grid-row: 2; }
  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: 1fr !important; }
    .project-card-featured,
    .project-card-small-1,
    .project-card-small-2,
    .project-card-small-3 {
      grid-column: 1 !important;
      grid-row: auto !important;
    }
  }
</style>
